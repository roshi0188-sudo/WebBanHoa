@model WebBanHoa.Models.Category

@{
    ViewData["Title"] = "Tạo danh mục mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <a asp-action="Index" class="text-decoration-none text-secondary d-inline-flex align-items-center gap-2 mb-4 transition-all hover-primary">
                <i class="bi bi-chevron-left"></i> Quay về quản lý
            </a>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="p-4 text-white" style="background: linear-gradient(135deg, #0058be 0%, #007bff 100%);">
                    <h4 class="fw-bold m-0"><i class="bi bi-folder-plus me-2"></i>Tạo Danh Mục</h4>
                    <p class="small m-0 text-white-75 mt-1">Phân loại hoa mới cho cửa hàng</p>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="Add" method="post">
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-dark mb-2">Tên danh mục hoa</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-4 ps-3"><i class="bi bi-tag text-primary"></i></span>
                                <input asp-for="Name" class="form-control rounded-end-4 py-2 border-start-0 shadow-none" placeholder="Ví dụ: Hoa khai trương..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="d-flex gap-3 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill w-100 py-2 fw-semibold"> Hủy bỏ </a>
                            <button type="submit" class="btn btn-primary rounded-pill w-100 py-2 fw-semibold shadow-sm border-0" style="background-color: #0058be;"> Lưu danh mục </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-all {
        transition: all 0.3s ease;
    }

    .hover-primary:hover {
        color: #0058be !important;
        transform: translateX(-5px);
    }

    .text-white-75 {
        color: rgba(255,255,255,0.75);
    }
    /* Hiệu ứng focus cho input */
    .form-control:focus {
        border-color: #0058be;
        box-shadow: 0 0 0 0.25rem rgba(0, 88, 190, 0.15);
    }
</style>