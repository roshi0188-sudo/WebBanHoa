@model IEnumerable<WebBanHoa.Models.Product>
@{
    ViewData["Title"] = "Trang chủ - Floral LAM";
}

<div class="position-relative text-center text-white bg-dark mb-5" style="background: url('/images/banner.jpg') no-repeat center center; background-size: cover; height: 350px;">
    <div class="position-absolute top-50 start-50 translate-middle w-100" style="background: rgba(255, 192, 203, 0.35); padding: 60px 0;">
        <h1 class="display-4 fw-bold">Trao gửi yêu thương qua từng cánh hoa</h1>
        <p class="lead fs-4">Bộ sưu tập hoa tươi mới nhất từ Floral LAM</p>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-md-3">
            <div class="card mb-4 border-light shadow-sm">
                <div class="card-body">
                    <h6 class="text-primary fw-bold mb-3">Kết nối với chúng tôi</h6>
                    <ul class="list-unstyled small lh-lg">
                        <li><i class="bi bi-facebook text-primary"></i> Facebook</li>
                        <li><i class="bi bi-twitter-x text-dark"></i> Twitter</li>
                        <li><i class="bi bi-instagram text-danger"></i> Instagram</li>
                    </ul>

                    <hr />
                    <h6 class="text-primary fw-bold mb-3">Danh mục</h6>
                    <ul class="list-unstyled small lh-lg">
                        <li><a href="#" class="text-decoration-none text-muted">➔ Hoa Khai Trương</a></li>
                        <li><a href="#" class="text-decoration-none text-muted">➔ Hoa Sinh Nhật</a></li>
                        <li><a href="#" class="text-decoration-none text-muted">➔ Hoa Dạm Hỏi</a></li>
                    </ul>

                    <hr />
                    <h6 class="text-primary fw-bold mb-3">Khoảng giá</h6>
                    <div class="form-check small mb-2">
                        <input class="form-check-input" type="radio" name="price" id="p1">
                        <label class="form-check-label text-muted" for="p1">Dưới 500.000đ</label>
                    </div>
                    <div class="form-check small">
                        <input class="form-check-input" type="radio" name="price" id="p2">
                        <label class="form-check-label text-muted" for="p2">500.000đ - 1.000.000đ</label>
                    </div>
                </div>
            </div>

            <div class="p-3 mb-3 text-white text-center rounded-3 shadow-sm" style="background: linear-gradient(135deg, #e14eca 0%, #ba25fc 100%);">
                <small>Ưu đãi sinh viên</small>
                <h4 class="fw-bold m-0">Giảm 10%</h4>
                <small class="text-white border border-white px-2 py-0.5 rounded d-inline-block mt-2">Mã: FLAM10</small>
            </div>
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="text-primary fw-bold m-0">Sản phẩm nổi bật</h3>
                <a asp-action="Add" class="btn btn-sm text-white rounded-pill px-3" style="background-color: #ff69b4;"><i class="bi bi-plus-circle"></i> Quản lý: Thêm hoa</a>
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var product in Model)
                {
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative">
                            <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://placeholder.co/300" : product.ImageUrl)" class="card-img-top" style="height: 260px; object-fit: cover;" alt="@product.Name">

                            <div class="card-body d-flex flex-column justify-content-between">
                                <div>
                                    <h5 class="card-title fw-bold text-dark mb-1">@product.Name</h5>
                                    <p class="card-text text-muted small mb-2">@product.Description</p>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="text-danger fw-bold fs-5">@string.Format("{0:N0}đ", product.Price)</span>
                                    <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">Chi tiết</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>