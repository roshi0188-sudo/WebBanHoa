@model WebBanHoa.Models.Product

@{
    ViewData["Title"] = "Cập nhật thông tin hoa";
}

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <h2 class="text-primary fw-bold mb-4">
                <i class="bi bi-pencil-square"></i> Chỉnh Sửa Thông Tin Bó Hoa
            </h2>

            <form asp-action="Update" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" /> <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Tên Sản Phẩm / Bó Hoa</label>
                    <input asp-for="Name" class="form-control rounded-3" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label fw-semibold">Giá bán hiện tại (đ)</label>
                        <input asp-for="Price" type="number" class="form-control rounded-3" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="OldPrice" class="form-label fw-semibold text-muted">Giá gốc / Giá cũ (đ)</label>
                        <input asp-for="OldPrice" type="number" class="form-control rounded-3" placeholder="Hiện gạch ngang giảm giá" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Danh Mục Hoa</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select rounded-3"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Mô tả ngắn (Dòng tóm tắt ở trang chủ)</label>
                    <input asp-for="Description" class="form-control rounded-3" />
                </div>

                <div class="mb-3">
                    <label asp-for="Ingredients" class="form-label fw-semibold">Thành phần các loại hoa chính</label>
                    <input asp-for="Ingredients" class="form-control rounded-3" placeholder="Ví dụ: Hồng Pastel, Tulip trắng, Lá Bạc" />
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold">Mô tả chi tiết câu chuyện của hoa</label>
                    <textarea asp-for="Description" class="form-control rounded-3" rows="4"></textarea>
                </div>

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-4 p-3 bg-light rounded-3 d-flex align-items-center gap-3">
                        <img src="@Model.ImageUrl" alt="Ảnh hiện tại" class="rounded border" style="width: 80px; height: 80px; object-fit: cover;" />
                        <div>
                            <small class="text-muted d-block">Ảnh đại diện hiện tại</small>
                            <span class="text-truncate d-inline-block small fw-bold text-secondary" style="max-width: 250px;">@Model.ImageUrl</span>
                        </div>
                    </div>
                }

                <div class="d-flex gap-2 justify-content-end border-top pt-3">
                    <a asp-action="Index" class="btn btn-light border rounded-pill px-4">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">Lưu cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>