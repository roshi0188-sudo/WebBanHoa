@model WebBanHoa.Models.Category

@{
    ViewData["Title"] = "Tạo danh mục mới";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <a asp-action="Index" class="text-decoration-none text-muted small d-inline-flex align-items-center gap-1 mb-3 hover-pink">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="bg-primary text-white p-4">
                    <h4 class="fw-bold m-0"><i class="bi bi-folder-plus me-2"></i>Tạo Danh Mục Mới</h4>
                    <p class="small m-0 text-white-50 mt-1">Bổ sung thêm nhóm phân loại hoa mới vào hệ thống</p>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="Add" method="post">

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary small text-uppercase">Tên danh mục hoa</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted rounded-start-3"><i class="bi bi-tag"></i></span>
                                <input asp-for="Name" class="form-control rounded-end-3 py-2 border-start-0" placeholder="Ví dụ: Hoa khai trương, Hoa cưới..." />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex gap-3 pt-2 border-top">
                            <a asp-action="Index" class="btn btn-light border rounded-pill w-100 py-2.5 fw-semibold text-secondary"> Hủy bỏ </a>
                            <button type="submit" class="btn btn-primary rounded-pill w-100 py-2.5 fw-semibold shadow-sm"> Lưu dữ liệu </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .hover-pink:hover {
        color: #d63384 !important;
    }
</style>