@model WebBanHoa.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="mb-4 d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-sm btn-light border"><i class="bi bi-arrow-left"></i> Quay lại cửa hàng</a>
        <div>
            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-secondary me-1" style="background-color: #BDB5D5;">Sửa hoa này</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger" style="background-color: #FFF3CD;">Xóa</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 text-center">
            <div class="border rounded-4 p-3 bg-white mb-3 shadow-sm">
                <img id="mainImg" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://placeholder.co/500" : Model.ImageUrl)" class="img-fluid rounded-3" style="max-height: 440px; object-fit: contain;" />
            </div>

            <div class="d-flex gap-2 justify-content-center">
                <img src="@Model.ImageUrl" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;" onclick="document.getElementById('mainImg').src = this.src" />
                @if (Model.ImageUrls != null)
                {
                    foreach (var img in Model.ImageUrls)
                    {
                        <img src="@img" class="img-thumbnail" style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;" onclick="document.getElementById('mainImg').src = this.src" />
                    }
                }
            </div>
        </div>

        <div class="col-md-6 ps-md-4">
            <span class="badge bg-warning text-dark mb-2">BÁN CHẠY NHẤT</span>
            <h1 class="fw-bold text-dark mb-1">@Model.Name</h1>

            <div class="text-warning small mb-3">
                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                <span class="text-muted small ms-2">(4.9/5 dựa trên 128 khách hàng)</span>
            </div>

            <div class="mb-4">
                <span class="text-danger fw-bold fs-2 me-3">@string.Format("{0:N0}đ", Model.Price)</span>
                @if (Model.OldPrice.HasValue)
                {
                    <span class="text-muted text-decoration-line-through fs-5">@string.Format("{0:N0}đ", Model.OldPrice.Value)</span>
                }
            </div>
            <div class="mb-2">
                <span class="badge bg-light text-secondary border rounded-pill px-3 py-2 fw-semibold">
                    <i class="bi bi-tag-fill text-primary me-1"></i> Danh mục: @ViewBag.CategoryName
                </span>
            </div>

            <p class="text-muted fst-italic mb-4 fs-5">"@Model.Description"</p>

            <div class="d-flex align-items-center mb-4">
                <div class="input-group" style="width: 140px;">
                    <button class="btn btn-outline-secondary" type="button" onclick="changeCount(-1)">-</button>
                    <input type="text" id="countInput" class="form-control text-center fw-bold" value="1" readonly>
                    <button class="btn btn-outline-secondary" type="button" onclick="changeCount(1)">+</button>
                </div>
            </div>

            <div class="card bg-light border-0 mb-4 rounded-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3"><i class="bi bi-flower1 text-success"></i> Thành phần chính</h6>
                    <div class="row g-2 text-dark small">
                        @if (!string.IsNullOrEmpty(Model.Ingredients))
                        {
                            foreach (var item in Model.Ingredients.Split(','))
                            {
                                <div class="col-6">✔ @item.Trim()</div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-muted">Chưa cập nhật thành phần chi tiết.</div>
                        }
                    </div>
                    <div class="text-muted mt-3" style="font-size: 0.75rem; line-height: 1.4;">
                        * Lưu ý: Tùy theo mùa mà loại lá phụ có thể thay đổi đôi chút nhưng vẫn đảm bảo thẩm mỹ 100%.
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 align-items-center mb-4">
                <button type="submit" class="btn btn-outline-dark btn-lg w-100 rounded-pill py-3 fw-bold shadow-sm">
                    <i class="bi bi-cart-plus-fill me-2"></i>THÊM VÀO GIỎ HÀNG
                </button>

                <button type="button" class="btn btn-danger btn-lg w-100 rounded-pill py-3 fw-bold shadow-sm">
                    ĐẶT NGAY
                </button>
            </div>

            <div class="d-flex justify-content-around text-center border-top pt-3 text-muted small">
                <div><i class="bi bi-truck fs-3 text-dark d-block mb-1"></i> Giao nhanh 2h</div>
                <div><i class="bi bi-camera fs-3 text-dark d-block mb-1"></i> Gửi ảnh thực tế</div>
                <div><i class="bi bi-heart-fill fs-3 text-dark d-block mb-1"></i> Tặng kèm thiệp</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeCount(val) {
            var input = document.getElementById('countInput');
            var res = parseInt(input.value) + val;
            if (res >= 1) input.value = res;
        }
    </script>
}