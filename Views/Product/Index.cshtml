@model IEnumerable<WebBanHoa.Models.Product>

@{
    ViewData["Title"] = "Tất cả sản phẩm - Floral LAM";
}

<div class="container mt-5 mb-5">
    <div class="mb-4 border-bottom pb-3">
        <h3 class="fw-bold text-dark m-0">Bộ Sưu Tập Hoa Tươi</h3>
        <p class="text-muted small m-0 mt-1">Khám phá những mẫu hoa nghệ thuật mới nhất được thiết kế bởi Floral LAM</p>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col">
                    <a asp-controller="Product" asp-action="Display" asp-route-id="@item.Id" class="text-decoration-none card-wrapper-link">

                        <div class="card h-100 border-0 shadow-sm rounded-3 overflow-hidden product-click-card bg-white">
                            <div class="position-relative overflow-hidden img-box">
                                <img src="@item.ImageUrl" class="card-img-top" style="height: 250px; object-fit: cover;" alt="@item.Name">
                            </div>

                            <div class="card-body text-center d-flex flex-column justify-content-between p-3">
                                <div>
                                    <h6 class="card-title fw-bold text-dark text-truncate mb-1">@item.Name</h6>
                                    @if (item.Description != null)
                                    {
                                        <p class="text-muted small text-truncate mb-2" style="font-size: 0.8rem;">@item.Description</p>
                                    }
                                    <p class="card-text text-danger fw-bold m-0 mb-2">@item.Price.ToString("N0")đ</p>
                                </div>

                                <div class="btn btn-sm btn-outline-danger rounded-pill w-100 fw-semibold py-1.5 mt-auto">
                                    Chi tiết
                                </div>
                            </div>
                        </div>

                    </a>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i> Hiện tại hệ thống chưa có sản phẩm hoa nào.
            </div>
        }
    </div>
</div>

<style>
    /* Biến toàn bộ thẻ bao bọc thành khối không bị đổi màu chữ link */
    .card-wrapper-link {
        display: block;
        color: inherit;
    }

    .product-click-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        border: 1px solid rgba(0,0,0,0.03) !important;
    }

    /* Hiệu ứng nhấc nhẹ hộp hoa lên khi trỏ chuột vào */
    .card-wrapper-link:hover .product-click-card {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.1) !important;
    }

    /* Phóng to ảnh nhẹ bên trong khung khi hover */
    .img-box img {
        transition: transform 0.4s ease;
    }

    .card-wrapper-link:hover .img-box img {
        transform: scale(1.04);
    }
</style>