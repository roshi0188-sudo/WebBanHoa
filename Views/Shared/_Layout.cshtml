<!DOCTYPE html>
<html lang="vi" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Floral LAM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .wrapper-layout {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .main-content {
            flex: 1 0 auto;
        }

        .footer-dark {
            flex-shrink: 0;
            background-color: #2b3e50;
            color: #adb5bd;
            padding: 40px 0 20px 0;
        }

        .navbar-brand {
            font-weight: bold;
            color: #d63384 !important;
        }

        .footer-dark h5 {
            color: #f8f9fa;
            border-bottom: 2px solid #d63384;
            padding-bottom: 5px;
            display: inline-block;
        }

        .navbar-nav .nav-link {
            transition: all 0.2s ease-in-out;
            font-weight: 500;
        }

            .navbar-nav .nav-link:hover {
                font-weight: bold !important;
                color: #d63384 !important;
            }

        .navbar-nav .btn-outline-success {
            transition: all 0.2s ease-in-out;
        }

            .navbar-nav .btn-outline-success:hover {
                font-weight: bold !important;
                background-color: #198754 !important;
                color: white !important;
            }
    </style>
</head>
<body class="h-100">

    <div class="wrapper-layout">

        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow sticky-top py-2">
                <div class="container">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">🌸 Floral LAM</a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarFloralLam" aria-controls="navbarFloralLam" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse justify-content-end" id="navbarFloralLam">
                        <ul class="navbar-nav align-items-center gap-2">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang chủ</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Category" asp-action="Index">Quản lý danh mục</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" href="#">Liên hệ</a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a class="btn btn-outline-success rounded-pill px-3 py-1 d-flex align-items-center gap-2" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart-fill"></i> Giỏ hàng
                                    <span class="badge bg-success">0</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="main-content py-4">
            <div class="container">
                @RenderBody()
            </div>
        </main>

        <footer class="footer-dark">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 mb-3 mb-md-0">
                        <h5>🌸 FLORAL LAM</h5>
                        <p class="small mt-2">Chúng tôi gửi bạn những bó hoa tươi đẹp nhất, mang lại niềm vui cho mọi gia đình và đôi lứa.</p>
                    </div>
                    <div class="col-md-4 mb-3 mb-md-0">
                        <h5>CHÍNH SÁCH</h5>
                        <ul class="list-unstyled small mt-2 lh-lg">
                            <li>Giao hàng hỏa tốc</li>
                            <li>Chính sách hoàn tiền</li>
                            <li>Hướng dẫn bảo quản hoa</li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h5>LIÊN HỆ</h5>
                        <p class="small mt-2 mb-1"><i class="bi bi-geo-alt-fill"></i> 123 Phường An Nhơn, TP. Hồ Chí Minh</p>
                        <p class="small mb-1"><i class="bi bi-telephone-fill"></i> 0123 456 789</p>
                        <p class="small"><i class="bi bi-envelope-fill"></i> Florallam@gmail.com</p>
                    </div>
                </div>
                <div class="text-center pt-3 border-top border-secondary mt-3 small">
                    © 2026 Floral LAM. Trao hoa, trao yêu thương.
                </div>
            </div>
        </footer>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>