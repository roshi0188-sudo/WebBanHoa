@model WebBanHoa.Models.Category

@{
    ViewData["Title"] = "Cập nhật danh mục";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <a asp-action="Index" class="text-decoration-none text-secondary d-inline-flex align-items-center gap-2 mb-4 transition-all hover-primary">
                <i class="bi bi-chevron-left"></i> Quay về danh sách
            </a>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="p-4 text-white" style="background: linear-gradient(135deg, #343a40 0%, #000000 100%);">
                    <h4 class="fw-bold m-0"><i class="bi bi-pencil-square me-2"></i>Chỉnh Sửa</h4>
                    <p class="small m-0 text-white-75 mt-1">Cập nhật thông tin danh mục #@Model.Id</p>
                </div>

                <div class="card-body p-4 bg-white">
                    <form asp-action="Update" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark small text-uppercase">Mã định danh</label>
                            <div class="bg-light border rounded-3 p-2 px-3 text-muted font-monospace">
                                #@Model.Id
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-dark mb-2">Tên danh mục hoa</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 rounded-start-4 ps-3"><i class="bi bi-tag text-dark"></i></span>
                                <input asp-for="Name" class="form-control rounded-end-4 py-2 border-start-0 shadow-none" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small mt-2 d-block"></span>
                        </div>

                        <div class="d-flex gap-3 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill w-100 py-2 fw-semibold"> Hủy bỏ </a>
                            <button type="submit" class="btn btn-dark rounded-pill w-100 py-2 fw-semibold shadow-sm border-0"> Lưu thay đổi </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-all {
        transition: all 0.3s ease;
    }

    .hover-primary:hover {
        color: #000 !important;
        transform: translateX(-5px);
    }

    .text-white-75 {
        color: rgba(255,255,255,0.75);
    }

    .form-control:focus {
        border-color: #000;
        box-shadow: 0 0 0 0.25rem rgba(0,0,0,0.05);
    }
</style>