@model WebBanHoa.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-5">
    <div class="mb-4">
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left"></i> Quay lại cửa hàng
        </a>
    </div>

    <div class="row g-5 align-items-center">
        <div class="col-md-6">
            <div class="premium-card rounded-5 p-3 shadow-sm border-0" style="background: #ffffff;">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default_flower.jpg" : Model.ImageUrl)"
                     class="img-fluid rounded-4 w-100"
                     style="height: 500px; object-fit: cover;" />
            </div>
        </div>

        <div class="col-md-6">
            <span class="badge rounded-pill px-3 py-2 mb-2" style="background: #fdf2f8; color: #b4136d;">
                <i class="bi bi-stars"></i> BÁN CHẠY NHẤT
            </span>

            <h1 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif; color: #1f1a1e;">@Model.Name</h1>

            <div class="fs-4 fw-bold mb-4" style="color: #0058be;">
                @string.Format("{0:N0}đ", Model.Price)
            </div>

            <p class="text-muted fs-5 mb-4" style="font-family: 'Montserrat', sans-serif;">
                "@Model.Description"
            </p>

            <div class="d-flex align-items-center mb-4">
                <div class="input-group rounded-pill overflow-hidden border" style="width: 140px;">
                    <button class="btn btn-light" type="button" onclick="changeCount(-1)">-</button>
                    <input type="text" id="countInput" class="form-control text-center border-0" value="1" readonly>
                    <button class="btn btn-light" type="button" onclick="changeCount(1)">+</button>
                </div>
            </div>

            <div class="d-grid gap-3 d-md-flex">
                <button class="btn btn-outline-dark rounded-pill py-3 px-5 fw-bold">
                    THÊM VÀO GIỎ
                </button>
                <button class="btn rounded-pill py-3 px-5 fw-bold text-white"
                        style="background: linear-gradient(135deg, #0058be 0%, #fd56a7 100%);">
                    ĐẶT NGAY
                </button>
            </div>

            <div class="mt-5 p-4 rounded-4" style="background: #fff7fa;">
                <h6 class="fw-bold"><i class="bi bi-flower1"></i> Thông tin thiết kế</h6>
                <ul class="list-unstyled text-secondary small mt-2">
                    <li><i class="bi bi-check2"></i> Hoa tươi tuyển chọn trong ngày.</li>
                    <li><i class="bi bi-check2"></i> Gửi ảnh thực tế trước khi giao.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeCount(val) {
            let input = document.getElementById('countInput');
            let res = parseInt(input.value) + val;
            if (res >= 1) input.value = res;
        }
    </script>
}